echo ""
# Also just try each path that looks like a repo dir
python3 -c "
import json, subprocess, os
with open('/home/nick/.beads/registry.json') as f:
    reg = json.load(f)

def get_paths(obj):
    paths = []
    if isinstance(obj, str) and obj.startswith('/'):
        paths.append(obj)
    elif isinstance(obj, dict):
        for v in obj.values():
            paths.extend(get_paths(v))
    elif isinstance(obj, list):
        for v in obj:
            paths.extend(get_paths(v))
    return paths

for path in get_paths(reg):
    if os.path.isdir(path):
        print(f'--- {path} ---')
        r = subprocess.run(['bd', 'list'], cwd=path, capture_output=True, text=True, timeout=10)
        print(r.stdout[:500] or r.stderr[:200])
" 2>&1

echo "=== done ==="
