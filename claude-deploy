#!/usr/bin/env bash
# claude-deploy — manage Claude GitHub deploy credentials
# Commands: setup, token, profiles, status, preamble
set -e

CONFIG_DIR="${CLAUDE_DEPLOY_DIR:-$HOME/.config/claude-deploy}"
COMMAND=$1
shift || true

usage() {
    cat >&2 << 'USAGE'
Usage: claude-deploy <command> [options]

Commands:
  setup    [--org <n>]              Configure app ID and ingest PEM
  token    <owner/repo> [--org <n>] Get ephemeral token (copies to clipboard)
  handover <owner/repo> [--org <n>] Generate full session blob → wl-copy (paste into Claude)
  update                            Overwrite this script from main branch
  profiles                          List configured profiles
  status   [--org <n>]             Show current config

Options:
  --org <n>     Use named org/profile (default: "default")
  --profile <n> Alias for --org
USAGE
    exit 1
}

parse_profile() {
    PROFILE="default"
    POSITIONAL=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            --profile|--org)
                PROFILE="$2"
                shift 2
                ;;
            *)
                POSITIONAL+=("$1")
                shift
                ;;
        esac
    done
}

config_file() {
    if [[ "$1" == "default" ]]; then
        echo "$CONFIG_DIR/config"
    else
        echo "$CONFIG_DIR/config-$1"
    fi
}

load_config() {
    local file=$(config_file "$1")
    if [[ ! -f "$file" ]]; then
        echo "Error: no config for profile '$1' — run: claude-deploy setup --profile $1" >&2
        exit 1
    fi
    source "$file"
}

cmd_setup() {
    parse_profile "$@"
    local file=$(config_file "$PROFILE")
    mkdir -p "$CONFIG_DIR"

    echo "Setting up profile: $PROFILE"

    read -p "GitHub App ID: " APP_ID
    if [[ -z "$APP_ID" ]]; then
        echo "Error: App ID required" >&2
        exit 1
    fi

    read -p "Path to PEM file (will be copied to $CONFIG_DIR/): " PEM_SRC
    PEM_SRC="${PEM_SRC/#\~/$HOME}"
    if [[ ! -f "$PEM_SRC" ]]; then
        echo "Error: PEM not found at $PEM_SRC" >&2
        exit 1
    fi

    PEM_DEST="$CONFIG_DIR/private-key-$PROFILE.pem"
    cp "$PEM_SRC" "$PEM_DEST"
    chmod 600 "$PEM_DEST"
    echo "PEM copied to $PEM_DEST"

    cat > "$file" << CONF
APP_ID=$APP_ID
PEM_PATH=$PEM_DEST
CONF
    chmod 600 "$file"
    echo "✓ Profile '$PROFILE' saved to $file"
}

cmd_token() {
    parse_profile "$@"
    REPO="${POSITIONAL[0]}"

    if [[ -z "$REPO" ]]; then
        echo "Usage: claude-deploy token <owner/repo> [--profile <n>]" >&2
        exit 1
    fi

    load_config "$PROFILE"

    JWT=$(uvx --with pyjwt --with cryptography python3 - << PYEOF
import jwt, time
pem = open("$PEM_PATH").read()
now = int(time.time())
print(jwt.encode({"iat": now - 60, "exp": now + 600, "iss": "$APP_ID"}, pem, algorithm="RS256"))
PYEOF
)

    echo "JWT generated, looking up installation..." >&2

    INSTALL=$(gh api "/repos/$REPO/installation" \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json")

    INSTALL_ID=$(echo "$INSTALL" | jq -r '.id')

    if [[ "$INSTALL_ID" == "null" || -z "$INSTALL_ID" ]]; then
        echo "Error: app not installed on $REPO" >&2
        echo "$INSTALL" | jq . >&2
        exit 1
    fi

    echo "Installation ID: $INSTALL_ID" >&2

    TOKEN=$(gh api "/app/installations/$INSTALL_ID/access_tokens" \
        --method POST \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" \
        --field "repositories[]=$(echo $REPO | cut -d'/' -f2)" \
        --jq '.token')

    EXPIRY=$(date -d '+1 hour' '+%H:%M %Z')
    echo "Token valid until: $EXPIRY" >&2

    if command -v wl-copy &> /dev/null; then
        echo -n "$TOKEN" | wl-copy
        echo "📋 Token copied to clipboard (valid until $EXPIRY)" >&2
    else
        echo "⚠️  wl-copy not found — copy the token below manually" >&2
    fi

    echo "$TOKEN"
}

cmd_profiles() {
    echo "Configured profiles:"
    for f in "$CONFIG_DIR"/config "$CONFIG_DIR"/config-*; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f")
        [[ "$name" == "config" ]] && name="default"
        [[ "$name" == config-* ]] && name="${name#config-}"
        source "$f"
        echo "  $name — App ID: $APP_ID, PEM: $PEM_PATH"
    done
}

cmd_status() {
    parse_profile "$@"
    load_config "$PROFILE"
    echo "Profile:  $PROFILE"
    echo "App ID:   $APP_ID"
    echo "PEM:      $PEM_PATH"
    [[ -f "$PEM_PATH" ]] && echo "PEM file: ✓ exists" || echo "PEM file: ✗ missing"
}

cmd_handover() {
    parse_profile "$@"
    REPO="${POSITIONAL[0]}"

    if [[ -z "$REPO" ]]; then
        echo "Usage: claude-deploy handover <owner/repo> [--org <n>]" >&2
        exit 1
    fi

    # Infer profile if not explicitly set
    if [[ "$PROFILE" == "default" ]]; then
        OWNER=$(echo "$REPO" | cut -d'/' -f1)
        OWNER_CFG=$(config_file "$OWNER")
        if [[ -f "$OWNER_CFG" ]]; then
            # Repo owner matches a profile name
            PROFILE="$OWNER"
            echo "Using profile '$PROFILE' (inferred from repo owner)" >&2
        else
            # Fall back: if exactly one non-default profile exists, use it
            PROFILES=("$CONFIG_DIR"/config-*)
            PROFILES=($(for f in "${PROFILES[@]}"; do [[ -f "$f" ]] && echo "$f"; done))
            if [[ ${#PROFILES[@]} -eq 1 ]]; then
                PROFILE=$(basename "${PROFILES[0]}" | sed 's/^config-//')
                echo "Using profile '$PROFILE' (only profile configured)" >&2
            fi
        fi
    fi

    load_config "$PROFILE"

    echo "Generating token..." >&2

    JWT=$(uvx --with pyjwt --with cryptography python3 - << PYEOF
import jwt, time
pem = open("$PEM_PATH").read()
now = int(time.time())
print(jwt.encode({"iat": now - 60, "exp": now + 600, "iss": "$APP_ID"}, pem, algorithm="RS256"))
PYEOF
)

    INSTALL=$(gh api "/repos/$REPO/installation" \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json")

    INSTALL_ID=$(echo "$INSTALL" | jq -r '.id')

    if [[ "$INSTALL_ID" == "null" || -z "$INSTALL_ID" ]]; then
        echo "Error: app not installed on $REPO" >&2
        exit 1
    fi

    TOKEN=$(gh api "/app/installations/$INSTALL_ID/access_tokens" \
        --method POST \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" \
        --field "repositories[]=$(echo $REPO | cut -d'/' -f2)" \
        --jq '.token')

    EXPIRY=$(date -d '+1 hour' '+%H:%M %Z')

    BLOB=$(cat << HANDOVER
## claude-deploy session — $REPO

Repo: \`$REPO\`
Token (valid until $EXPIRY):
\`\`\`
$TOKEN
\`\`\`

Clone and push:
\`\`\`sh
git clone https://x-access-token:$TOKEN@github.com/$REPO.git
# always use x-access-token: prefix — bare token fails on push
git remote set-url origin https://x-access-token:$TOKEN@github.com/$REPO.git
git push origin main
\`\`\`

Skill: https://github.com/fluid-notion-labs/claude-deploy-skill
HANDOVER
)

    if command -v wl-copy &> /dev/null; then
        echo -n "$BLOB" | wl-copy
        echo "📋 Handover copied to clipboard (token valid until $EXPIRY)" >&2
    else
        echo "⚠️  wl-copy not found" >&2
        echo "$BLOB"
    fi
}

cmd_update() {
    DEST=$(realpath "$0")
    URL="https://raw.githubusercontent.com/fluid-notion-labs/claude-deploy-skill/main/claude-deploy"
    echo "Updating $DEST from main..." >&2
    curl -fsSL "$URL" -o "$DEST"
    chmod +x "$DEST"
    echo "✓ Updated" >&2
}

case "$COMMAND" in
    setup)    cmd_setup "$@" ;;
    token)    cmd_token "$@" ;;
    handover) cmd_handover "$@" ;;
    update)   cmd_update ;;
    profiles) cmd_profiles ;;
    status)   cmd_status "$@" ;;
    *)        usage ;;
esac
