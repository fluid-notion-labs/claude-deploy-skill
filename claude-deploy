#!/usr/bin/env bash
# claude-deploy — manage Claude GitHub deploy credentials
# Commands: setup, token, handover, update, profiles, status
set -e

CONFIG_DIR="${CLAUDE_DEPLOY_DIR:-$HOME/.config/claude-deploy}"
COMMAND=$1
shift || true

# Check for --no-update flag anywhere in args
NO_UPDATE=0
FILTERED_ARGS=()
for arg in "$@"; do
    if [[ "$arg" == "--no-update" ]]; then
        NO_UPDATE=1
    else
        FILTERED_ARGS+=("$arg")
    fi
done
set -- "${FILTERED_ARGS[@]}"

# Auto-update: if enabled in global config, update before running (except during update/config)
GLOBAL_CFG="$CONFIG_DIR/config"
if [[ "$NO_UPDATE" == "0" && "$COMMAND" != "update" && "$COMMAND" != "watch" && "$COMMAND" != "config" && -f "$GLOBAL_CFG" ]]; then
    source "$GLOBAL_CFG"
    if [[ "${AUTO_UPDATE:-0}" == "1" ]]; then
        DEST=$(command -v claude-deploy 2>/dev/null || realpath "$0")
        REPO_DIR="${CLAUDE_DEPLOY_REPO:-$HOME/.config/claude-deploy/repo}"
        TMP=$(mktemp)
        echo "Auto-updating..." >&2
        if [[ -d "$REPO_DIR/.git" ]]; then
            git -C "$REPO_DIR" pull --ff-only origin main -q
        else
            git clone -q https://github.com/fluid-notion-labs/claude-deploy-skill.git "$REPO_DIR"
        fi
        cp "$REPO_DIR/claude-deploy" "$TMP"
        if bash -n "$TMP" 2>/dev/null; then
            mv "$TMP" "$DEST"
            chmod +x "$DEST"
            exec "$DEST" "$COMMAND" "$@" --no-update
        else
            echo "⚠️  Auto-update failed syntax check, continuing with current version" >&2
            rm -f "$TMP"
        fi
    fi
fi

usage() {
    cat >&2 << 'USAGE'
Usage: claude-deploy <command> [options]

Commands:
  setup    [--org <n>]              Configure app ID and ingest PEM
  token    <owner/repo> [--org <n>] Get ephemeral token (copies to clipboard)
  handover [<owner/repo>] [--org <n>] Generate session blob → wl-copy; lists all repos if no repo given
  open     [--org <n>]             Open GitHub App settings to add repos
  update                            Overwrite this script from main branch
  watch                             Poll repo every 5s, print new commits
  config   auto-update [on|off]    Toggle auto-update on each run
  profiles                          List configured profiles
  status   [--org <n>]             Show current config

Options:
  --org <n>     Use named org (default: "default")
USAGE
    exit 1
}

parse_profile() {
    PROFILE="default"
    POSITIONAL=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            --org)
                PROFILE="$2"
                shift 2
                ;;
            *)
                POSITIONAL+=("$1")
                shift
                ;;
        esac
    done
}

config_file() {
    if [[ "$1" == "default" ]]; then
        echo "$CONFIG_DIR/config"
    else
        echo "$CONFIG_DIR/config-$1"
    fi
}

load_config() {
    local file=$(config_file "$1")
    if [[ ! -f "$file" ]]; then
        echo "Error: no config for org '$1' — run: claude-deploy setup --org $1" >&2
        exit 1
    fi
    source "$file"
}

cmd_setup() {
    parse_profile "$@"
    local file=$(config_file "$PROFILE")
    mkdir -p "$CONFIG_DIR"

    echo "Setting up org: $PROFILE"

    read -p "GitHub App ID: " APP_ID
    if [[ -z "$APP_ID" ]]; then
        echo "Error: App ID required" >&2
        exit 1
    fi

    read -p "Path to PEM file (will be copied to $CONFIG_DIR/): " PEM_SRC
    PEM_SRC="${PEM_SRC/#\~/$HOME}"
    if [[ ! -f "$PEM_SRC" ]]; then
        echo "Error: PEM not found at $PEM_SRC" >&2
        exit 1
    fi

    PEM_DEST="$CONFIG_DIR/private-key-$PROFILE.pem"
    cp "$PEM_SRC" "$PEM_DEST"
    chmod 600 "$PEM_DEST"
    echo "PEM copied to $PEM_DEST"

    # Auto-update prompt only for default org (global setting)
    local AUTO_UPDATE=0
    if [[ "$PROFILE" == "default" ]]; then
        read -p "Enable auto-update on each run? [y/N] " AU
        [[ "$AU" =~ ^[Yy] ]] && AUTO_UPDATE=1
    fi

    cat > "$file" << CONF
APP_ID=$APP_ID
PEM_PATH=$PEM_DEST
AUTO_UPDATE=$AUTO_UPDATE
CONF
    chmod 600 "$file"
    echo "✓ Org '$PROFILE' saved to $file"
}

cmd_config() {
    # claude-deploy config auto-update [on|off]
    local key="${POSITIONAL[0]:-}"
    local val="${POSITIONAL[1]:-}"
    local file=$(config_file "default")
    mkdir -p "$CONFIG_DIR"
    [[ ! -f "$file" ]] && touch "$file" && chmod 600 "$file"

    case "$key" in
        auto-update)
            case "$val" in
                on|1)  setting=1 ;;
                off|0) setting=0 ;;
                *)
                    # Toggle current
                    source "$file" 2>/dev/null || true
                    setting=$(( 1 - ${AUTO_UPDATE:-0} ))
                    ;;
            esac
            if grep -q "^AUTO_UPDATE=" "$file" 2>/dev/null; then
                sed -i "s/^AUTO_UPDATE=.*/AUTO_UPDATE=$setting/" "$file"
            else
                echo "AUTO_UPDATE=$setting" >> "$file"
            fi
            [[ "$setting" == "1" ]] && echo "✓ Auto-update enabled" || echo "✓ Auto-update disabled"
            ;;
        *)
            echo "Usage: claude-deploy config auto-update [on|off]" >&2
            exit 1
            ;;
    esac
}

infer_profile() {
    local repo="$1"
    if [[ "$PROFILE" == "default" ]]; then
        local owner=$(echo "$repo" | cut -d'/' -f1)
        local owner_cfg=$(config_file "$owner")
        if [[ -f "$owner_cfg" ]]; then
            PROFILE="$owner"
            echo "Using org '$PROFILE' (inferred from repo owner)" >&2
        else
            local profiles=("$CONFIG_DIR"/config-*)
            profiles=($(for f in "${profiles[@]}"; do [[ -f "$f" ]] && echo "$f"; done))
            if [[ ${#profiles[@]} -eq 1 ]]; then
                PROFILE=$(basename "${profiles[0]}" | sed 's/^config-//')
                echo "Using profile '$PROFILE' (only profile configured)" >&2
            fi
        fi
    fi
}

cmd_token() {
    parse_profile "$@"
    REPO="${POSITIONAL[0]}"

    if [[ -z "$REPO" ]]; then
        echo "Usage: claude-deploy token <owner/repo> [--org <n>]" >&2
        exit 1
    fi

    infer_profile "$REPO"
    load_config "$PROFILE"

    JWT=$(uvx --with pyjwt --with cryptography python3 - << PYEOF
import jwt, time
pem = open("$PEM_PATH").read()
now = int(time.time())
print(jwt.encode({"iat": now - 60, "exp": now + 600, "iss": "$APP_ID"}, pem, algorithm="RS256"))
PYEOF
)

    echo "JWT generated, looking up installation..." >&2

    set +e
    INSTALL=$(gh api "/repos/$REPO/installation" \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" 2>&1)
    GH_EXIT=$?
    set -e
    if [[ $GH_EXIT -ne 0 ]]; then
        OWNER=$(echo "$REPO" | cut -d'/' -f1)
        echo "Error: app not installed on '$REPO'" >&2
        echo "Grant access at:" >&2
        echo "  https://github.com/organizations/$OWNER/settings/installations" >&2
        exit 1
    fi

    INSTALL_ID=$(echo "$INSTALL" | jq -r '.id')

    if [[ "$INSTALL_ID" == "null" || -z "$INSTALL_ID" ]]; then
        echo "Error: app not installed on $REPO" >&2
        echo "$INSTALL" | jq . >&2
        exit 1
    fi

    echo "Installation ID: $INSTALL_ID" >&2

    TOKEN=$(gh api "/app/installations/$INSTALL_ID/access_tokens" \
        --method POST \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" \
        --jq '.token')

    EXPIRY=$(date -d '+1 hour' '+%H:%M %Z')
    echo "Token valid until: $EXPIRY" >&2

    if command -v wl-copy &> /dev/null; then
        echo -n "$TOKEN" | wl-copy
        echo "📋 Token copied to clipboard (valid until $EXPIRY)" >&2
    else
        echo "⚠️  wl-copy not found — copy the token below manually" >&2
    fi

    echo "$TOKEN"
}

cmd_profiles() {
    echo "Configured orgs:"
    for f in "$CONFIG_DIR"/config "$CONFIG_DIR"/config-*; do
        [[ -f "$f" ]] || continue
        name=$(basename "$f")
        [[ "$name" == "config" ]] && name="default"
        [[ "$name" == config-* ]] && name="${name#config-}"
        source "$f"
        echo "  $name — App ID: $APP_ID, PEM: $PEM_PATH"
    done
}

cmd_status() {
    parse_profile "$@"
    load_config "$PROFILE"
    echo "Profile:  $PROFILE"
    echo "App ID:   $APP_ID"
    echo "PEM:      $PEM_PATH"
    [[ -f "$PEM_PATH" ]] && echo "PEM file: ✓ exists" || echo "PEM file: ✗ missing"
}

cmd_handover() {
    parse_profile "$@"
    REPO="${POSITIONAL[0]}"

    # If no repo given, infer org from single configured org or require --org
    if [[ -z "$REPO" ]]; then
        if [[ "$PROFILE" == "default" ]]; then
            local profiles=("$CONFIG_DIR"/config-*)
            profiles=($(for f in "${profiles[@]}"; do [[ -f "$f" ]] && echo "$f"; done))
            if [[ ${#profiles[@]} -eq 1 ]]; then
                PROFILE=$(basename "${profiles[0]}" | sed 's/^config-//')
                echo "Using profile '$PROFILE' (only profile configured)" >&2
            else
                echo "Usage: claude-deploy handover [<owner/repo>] [--org <n>]" >&2
                exit 1
            fi
        fi
    else
        infer_profile "$REPO"
    fi

    load_config "$PROFILE"

    echo "Generating token..." >&2

    JWT=$(uvx --with pyjwt --with cryptography python3 - << PYEOF
import jwt, time
pem = open("$PEM_PATH").read()
now = int(time.time())
print(jwt.encode({"iat": now - 60, "exp": now + 600, "iss": "$APP_ID"}, pem, algorithm="RS256"))
PYEOF
)

    # Get installation ID — use repo if given, else org-level lookup
    if [[ -n "$REPO" ]]; then
        set +e
        INSTALL=$(gh api "/repos/$REPO/installation" \
            --header "Authorization: Bearer $JWT" \
            --header "Accept: application/vnd.github+json" 2>&1)
        GH_EXIT=$?
        set -e
        if [[ $GH_EXIT -ne 0 ]]; then
            OWNER=$(echo "$REPO" | cut -d'/' -f1)
            echo "Error: app not installed on '$REPO'" >&2
            echo "Grant access at:" >&2
            echo "  https://github.com/organizations/$OWNER/settings/installations" >&2
            exit 1
        fi
    else
        INSTALL=$(gh api "/app/installations" \
            --header "Authorization: Bearer $JWT" \
            --header "Accept: application/vnd.github+json" \
            | jq "[.[] | select(.account.login == \"$PROFILE\")][0]")
    fi

    INSTALL_ID=$(echo "$INSTALL" | jq -r '.id')

    if [[ "$INSTALL_ID" == "null" || -z "$INSTALL_ID" ]]; then
        echo "Error: app not installed on '$PROFILE'" >&2
        exit 1
    fi

    # Get token first
    TOKEN=$(gh api "/app/installations/$INSTALL_ID/access_tokens" \
        --method POST \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" \
        --jq '.token')

    # List repos using the installation token
    REPOS_JSON=$(gh api "/installation/repositories" \
        --header "Authorization: token $TOKEN" \
        --header "Accept: application/vnd.github+json" \
        | jq -r '.repositories[].full_name')

    EXPIRY=$(date -d '+1 hour' '+%H:%M %Z')

    # Build repo list for blob
    if [[ -n "$REPO" ]]; then
        REPO_SECTION="Repo: \`$REPO\`"
        SESSION_TITLE="$REPO"
    else
        REPO_LIST=$(echo "$REPOS_JSON" | sed 's/^/- /')
        REPO_SECTION="Repos (ask user which to work on):
$REPO_LIST"
        SESSION_TITLE="$PROFILE"
    fi

    BLOB=$(cat << HANDOVER
## claude-deploy session — $SESSION_TITLE

$REPO_SECTION
Token (valid until $EXPIRY):
\`\`\`
$TOKEN
\`\`\`

Clone and push:
\`\`\`sh
git clone https://x-access-token:$TOKEN@github.com/<owner>/<repo>.git
git remote set-url origin https://x-access-token:$TOKEN@github.com/<owner>/<repo>.git
git push origin main
\`\`\`

Skill: https://github.com/fluid-notion-labs/claude-deploy-skill
HANDOVER
)

    if command -v wl-copy &> /dev/null; then
        echo -n "$BLOB" | wl-copy
        echo "📋 Handover copied to clipboard (token valid until $EXPIRY)" >&2
    else
        echo "⚠️  wl-copy not found" >&2
        echo "$BLOB"
    fi
}

cmd_open() {
    parse_profile "$@"
    load_config "$PROFILE"

    # Determine if org or personal account
    local owner="${PROFILE}"
    local url

    # Try org URL first, fall back to personal
    if [[ "$owner" == "default" ]]; then
        url="https://github.com/settings/installations"
    else
        url="https://github.com/organizations/$owner/settings/installations"
    fi

    echo "Opening: $url" >&2
    xdg-open "$url" 2>/dev/null || echo "$url"
}

cmd_update() {
    DEST=$(command -v claude-deploy 2>/dev/null || realpath "$0")
    REPO_DIR="${CLAUDE_DEPLOY_REPO:-$HOME/.config/claude-deploy/repo}"
    URL="https://github.com/fluid-notion-labs/claude-deploy-skill.git"

    if [[ -d "$REPO_DIR/.git" ]]; then
        echo "Pulling latest from main..." >&2
        git -C "$REPO_DIR" pull --ff-only origin main
    else
        echo "Cloning claude-deploy-skill..." >&2
        mkdir -p "$(dirname "$REPO_DIR")"
        git clone "$URL" "$REPO_DIR"
    fi

    TMP=$(mktemp)
    cp "$REPO_DIR/claude-deploy" "$TMP"
    if ! bash -n "$TMP" 2>/dev/null; then
        echo "✗ Updated file has syntax errors, aborting" >&2
        rm -f "$TMP"
        exit 1
    fi
    mv "$TMP" "$DEST"
    chmod +x "$DEST"
    echo "✓ Updated to $(git -C "$REPO_DIR" rev-parse --short HEAD)" >&2
}

cmd_watch() {
    REPO_DIR="${PWD}"
    INTERVAL=5

    if [[ ! -d "$REPO_DIR/.git" ]]; then
        echo "Error: not a git repo: $REPO_DIR" >&2
        exit 1
    fi

    BRANCH=$(git -C "$REPO_DIR" rev-parse --abbrev-ref HEAD)
    echo "Watching $REPO_DIR [$BRANCH] (every ${INTERVAL}s) — Ctrl-C to stop"
    while true; do
        BEFORE=$(git -C "$REPO_DIR" rev-parse HEAD)
        git -C "$REPO_DIR" pull --ff-only origin "$BRANCH" -q 2>/dev/null
        AFTER=$(git -C "$REPO_DIR" rev-parse HEAD)
        TS=$(date '+%H:%M:%S')
        if [[ "$BEFORE" != "$AFTER" ]]; then
            MSG=$(git -C "$REPO_DIR" log --oneline -1)
            echo "[$TS] ✓ $MSG"
        else
            echo "[$TS] — $(git -C "$REPO_DIR" rev-parse --short HEAD) (no change)"
        fi
        sleep "$INTERVAL"
    done
}

case "$COMMAND" in
    setup)    cmd_setup "$@" ;;
    token)    cmd_token "$@" ;;
    handover) cmd_handover "$@" ;;
    open)     cmd_open "$@" ;;
    update)   cmd_update ;;
    watch)    cmd_watch ;;
    config)   parse_profile "$@"; cmd_config ;;
    profiles) cmd_profiles ;;
    status)   cmd_status "$@" ;;
    *)        usage ;;
esac
