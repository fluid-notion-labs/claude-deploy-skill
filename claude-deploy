#!/usr/bin/env bash
# claude-deploy — manage Claude GitHub deploy credentials
# Commands: setup, token, handover, update, profiles, status
set -e

CONFIG_DIR="${CLAUDE_DEPLOY_DIR:-$HOME/.config/claude-deploy}"
COMMAND=$1
shift || true

# Check for --no-update flag anywhere in args
NO_UPDATE=0
FILTERED_ARGS=()
for arg in "$@"; do
    if [[ "$arg" == "--no-update" ]]; then
        NO_UPDATE=1
    else
        FILTERED_ARGS+=("$arg")
    fi
done
set -- "${FILTERED_ARGS[@]}"

# Auto-update: if enabled in global config, update before running (except during update/config)
# Skipped when sourced for unit tests (CLAUDE_DEPLOY_TEST=1)
GLOBAL_CFG="$CONFIG_DIR/config"
if [[ "${CLAUDE_DEPLOY_TEST:-0}" != "1" && "$NO_UPDATE" == "0" && "$COMMAND" != "update" && "$COMMAND" != "watch" && "$COMMAND" != "config" && -f "$GLOBAL_CFG" ]]; then
    source "$GLOBAL_CFG"
    if [[ "${AUTO_UPDATE:-0}" == "1" ]]; then
        echo "Auto-updating..." >&2
        DEST=$(command -v claude-deploy 2>/dev/null || realpath "$0")
        if _do_update --quiet --dest "$DEST"; then
            exec "$DEST" "$COMMAND" "$@" --no-update
        fi
        # _do_update failed syntax check — continue with current version (already warned)
    fi
fi

# Shared update logic for auto-update block and cmd_update.
# Usage: _do_update [--quiet] [--dest <path>]
#   --quiet:      suppress git output (for auto-update)
#   --dest <path>: install path (default: command -v claude-deploy || realpath $0)
# Returns 0 on success, 1 if syntax check fails (prints warning, cleans up).
# On failure with exit-worthy condition (e.g. git error), propagates exit.
_do_update() {
    local quiet=0 dest=""
    while [[ $# -gt 0 ]]; do
        case $1 in
            --quiet) quiet=1; shift ;;
            --dest)  dest="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    [[ -z "$dest" ]] && dest=$(command -v claude-deploy 2>/dev/null || realpath "$0")

    local repo_dir="${CLAUDE_DEPLOY_REPO:-${XDG_CACHE_HOME:-$HOME/.cache}/claude-deploy/repo}"
    local url="https://github.com/fluid-notion-labs/claude-deploy-skill.git"
    local git_q=(); [[ "$quiet" == "1" ]] && git_q=(-q)

    if [[ -d "$repo_dir/.git" ]]; then
        [[ "$quiet" == "0" ]] && echo "Pulling latest from main..." >&2
        git -C "$repo_dir" pull --ff-only origin main "${git_q[@]}"
    else
        [[ "$quiet" == "0" ]] && echo "Cloning claude-deploy-skill..." >&2
        mkdir -p "$(dirname "$repo_dir")"
        git clone "${git_q[@]}" "$url" "$repo_dir"
    fi

    local tmp
    tmp=$(mktemp)
    cp "$repo_dir/claude-deploy" "$tmp"
    if bash -n "$tmp" 2>/dev/null; then
        mv "$tmp" "$dest"
        chmod +x "$dest"

        # Install bash completion alongside binary update
        local comp_src="$repo_dir/completions/claude-deploy.bash"
        if [[ -f "$comp_src" ]]; then
            local comp_dir="${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions"
            mkdir -p "$comp_dir"
            cp "$comp_src" "$comp_dir/claude-deploy"
            if [[ "$quiet" == "0" ]]; then
                echo "✓ Completion installed → $comp_dir/claude-deploy" >&2
                # Detect whether the XDG completions dir will be auto-sourced.
                # bash-completion ≥2.8 scans XDG_DATA_DIRS; check if our dir is reachable.
                local will_autoload=0
                if declare -f _completion_loader > /dev/null 2>&1; then
                    # bash-completion is active in this shell — XDG scanning supported
                    will_autoload=1
                elif [[ -f /usr/share/bash-completion/bash_completion ]]; then
                    # package installed; will load in new shells even if not in this one
                    will_autoload=1
                fi
                if [[ "$will_autoload" == "0" ]]; then
                    echo "  ⚠  bash-completion not detected — completions won't load automatically." >&2
                    echo "     To enable, choose one:" >&2
                    echo "       a) Install bash-completion:  sudo apt install bash-completion  (or brew install bash-completion@2)" >&2
                    echo "       b) Add to ~/.bashrc:         source \"$comp_dir/claude-deploy\"" >&2
                    echo "     Then open a new shell." >&2
                else
                    echo "  ℹ  Open a new shell (or run: source \"$comp_dir/claude-deploy\")" >&2
                fi
            fi
        fi

        [[ "$quiet" == "0" ]] && echo "✓ Updated to $(git -C "$repo_dir" rev-parse --short HEAD)" >&2
        return 0
    else
        [[ "$quiet" == "1" ]] && echo "⚠️  Auto-update failed syntax check, continuing with current version" >&2 \
                               || echo "✗ Updated file has syntax errors, aborting" >&2
        rm -f "$tmp"
        return 1
    fi
}

usage() {
    cat >&2 << 'USAGE'
Usage: claude-deploy <command> [options]

Commands:
  setup    [--org <n>]              Configure app ID and ingest PEM
  token    <owner/repo> [--org <n>] Get ephemeral token (copies to clipboard)
  handover [<owner/repo>] [--org <n>] Generate session blob → clipboard; lists all repos if no repo given
  open     [--org <n>]             Open GitHub App settings to add repos
  update                            Overwrite this script from main branch
  watch    [--commands]              Poll repo every 5s, print new commits; --commands also runs .claude-deploy-run sentinels
  queue    [--log <name>] [--all]   List sentinels (pending/running/done); --log dumps execution log; --all shows full history
  config   auto-update [on|off]    Toggle auto-update on each run
  profiles                          List configured profiles
  status   [--org <n>]             Show current config

Options:
  --org <n>     Use named org (default: "default")
USAGE
    exit 1
}

# Parse --org flag and collect remaining positional args.
# Sets globals: PROFILE (string), POSITIONAL (array).
# These are intentionally global — infer_profile/infer_single_org also
# mutate PROFILE after parse, so localising it would require restructuring
# the call graph. Acceptable for a single-file script of this size.
parse_profile() {
    PROFILE="default"
    POSITIONAL=()
    while [[ $# -gt 0 ]]; do
        case $1 in
            --org)
                PROFILE="$2"
                shift 2
                ;;
            *)
                POSITIONAL+=("$1")
                shift
                ;;
        esac
    done
}

config_file() {
    if [[ "$1" == "default" ]]; then
        echo "$CONFIG_DIR/config"
    else
        echo "$CONFIG_DIR/config-$1"
    fi
}

load_config() {
    local file=$(config_file "$1")
    if [[ ! -f "$file" ]]; then
        echo "Error: no config for org '$1' — run: claude-deploy setup --org $1" >&2
        exit 1
    fi
    source "$file"
}

cmd_setup() {
    parse_profile "$@"
    local file=$(config_file "$PROFILE")
    mkdir -p "$CONFIG_DIR"

    echo "Setting up profile: $PROFILE"

    read -p "Account type — org or user? [org/user, default: org] " ACCT
    local ACCOUNT_TYPE="org"
    [[ "$ACCT" =~ ^[Uu] ]] && ACCOUNT_TYPE="user"

    read -p "GitHub App ID: " APP_ID
    if [[ -z "$APP_ID" ]]; then
        echo "Error: App ID required" >&2
        exit 1
    fi

    read -p "Path to PEM file (will be copied to $CONFIG_DIR/): " PEM_SRC
    PEM_SRC="${PEM_SRC/#\~/$HOME}"
    if [[ ! -f "$PEM_SRC" ]]; then
        echo "Error: PEM not found at $PEM_SRC" >&2
        exit 1
    fi

    PEM_DEST="$CONFIG_DIR/private-key-$PROFILE.pem"
    cp "$PEM_SRC" "$PEM_DEST"
    chmod 600 "$PEM_DEST"
    echo "PEM copied to $PEM_DEST"

    # Auto-update prompt only for default org (global setting)
    local AUTO_UPDATE=0
    if [[ "$PROFILE" == "default" ]]; then
        read -p "Enable auto-update on each run? [y/N] " AU
        [[ "$AU" =~ ^[Yy] ]] && AUTO_UPDATE=1
    fi

    cat > "$file" << CONF
APP_ID=$APP_ID
PEM_PATH=$PEM_DEST
ACCOUNT_TYPE=$ACCOUNT_TYPE
AUTO_UPDATE=$AUTO_UPDATE
CONF
    chmod 600 "$file"
    echo "✓ Org '$PROFILE' saved to $file"
}

cmd_config() {
    # claude-deploy config auto-update [on|off]
    # AUTO_UPDATE is a global setting — always written to the default config
    # regardless of --org. parse_profile is called only to consume the flag cleanly.
    local key="${POSITIONAL[0]:-}"
    local val="${POSITIONAL[1]:-}"
    local file=$(config_file "default")
    mkdir -p "$CONFIG_DIR"
    [[ ! -f "$file" ]] && touch "$file" && chmod 600 "$file"

    case "$key" in
        auto-update)
            case "$val" in
                on|1)  setting=1 ;;
                off|0) setting=0 ;;
                *)
                    # Toggle current
                    source "$file" 2>/dev/null || true
                    setting=$(( 1 - ${AUTO_UPDATE:-0} ))
                    ;;
            esac
            if grep -q "^AUTO_UPDATE=" "$file" 2>/dev/null; then
                sed -i "s/^AUTO_UPDATE=.*/AUTO_UPDATE=$setting/" "$file"
            else
                echo "AUTO_UPDATE=$setting" >> "$file"
            fi
            [[ "$setting" == "1" ]] && echo "✓ Auto-update enabled" || echo "✓ Auto-update disabled"
            ;;
        *)
            echo "Usage: claude-deploy config auto-update [on|off]" >&2
            exit 1
            ;;
    esac
}

# If PROFILE is still "default" and exactly one org is configured, use it.
# Sets PROFILE as a side effect; returns 0 on success, 1 if ambiguous.
infer_single_org() {
    local configs=("$CONFIG_DIR"/config-*)
    configs=($(for f in "${configs[@]}"; do [[ -f "$f" ]] && echo "$f"; done))
    if [[ ${#configs[@]} -eq 1 ]]; then
        PROFILE=$(basename "${configs[0]}" | sed 's/^config-//')
        echo "Using org '$PROFILE' (only org configured)" >&2
        return 0
    fi
    return 1
}

infer_profile() {
    local repo="$1"
    if [[ "$PROFILE" == "default" ]]; then
        local owner=$(echo "$repo" | cut -d'/' -f1)
        local owner_cfg=$(config_file "$owner")
        if [[ -f "$owner_cfg" ]]; then
            PROFILE="$owner"
            echo "Using org '$PROFILE' (inferred from repo owner)" >&2
        else
            infer_single_org || true
        fi
    fi
}

# Copy content to clipboard using the best available tool.
# Tries: wl-copy (Wayland), xclip (X11), xsel (X11).
# Exits with an error message if none are found.
clipboard_copy() {
    local content="$1"
    if command -v wl-copy &>/dev/null; then
        echo -n "$content" | wl-copy
    elif command -v xclip &>/dev/null; then
        echo -n "$content" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        echo -n "$content" | xsel --clipboard --input
    else
        echo "⚠️  No clipboard tool found (tried: wl-copy, xclip, xsel)" >&2
        echo "    Install one: wl-copy (Wayland) or xclip/xsel (X11)" >&2
        return 1
    fi
}

# Copy content to clipboard, or print to stdout as fallback.
# Usage: copy_or_print <content> <label> [--always-print]
#   --always-print: also print to stdout even when clipboard copy succeeds
copy_or_print() {
    local content="$1" label="$2" always_print="${3:-}"
    if clipboard_copy "$content"; then
        echo "📋 $label" >&2
        [[ "$always_print" == "--always-print" ]] && echo "$content" || true
    else
        echo "$content"
    fi
}

# Get installation ID for a repo. Requires $JWT to be set.
# Prints the install ID to stdout; exits with error message on failure.
get_install_id() {
    local repo="$1"
    local install
    set +e
    install=$(gh api "/repos/$repo/installation" \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" 2>&1)
    local rc=$?
    set -e
    if [[ $rc -ne 0 ]]; then
        local owner=$(echo "$repo" | cut -d'/' -f1)
        echo "Error: app not installed on '$repo'" >&2
        echo "Grant access at:" >&2
        echo "  https://github.com/organizations/$owner/settings/installations" >&2
        exit 1
    fi
    local id
    id=$(echo "$install" | jq -r '.id')
    if [[ "$id" == "null" || -z "$id" ]]; then
        echo "Error: app not installed on '$repo'" >&2
        echo "$install" | jq . >&2
        exit 1
    fi
    echo "$id"
}

# Requires $PEM_PATH and $APP_ID to be set (via load_config)
generate_jwt() {
    uvx --with pyjwt --with cryptography python3 - << PYEOF
import jwt, time
pem = open("$PEM_PATH").read()
now = int(time.time())
print(jwt.encode({"iat": now - 60, "exp": now + 600, "iss": "$APP_ID"}, pem, algorithm="RS256"))
PYEOF
}

cmd_token() {
    parse_profile "$@"
    REPO="${POSITIONAL[0]}"

    # Infer repo from git remote if not explicitly given and we're in a git repo
    if [[ -z "$REPO" ]]; then
        local remote_url
        remote_url=$(git remote get-url origin 2>/dev/null || true)
        if [[ -n "$remote_url" ]]; then
            REPO=$(echo "$remote_url" | sed -E 's|.*github\.com[:/](.+/.+)\.git.*|\1|; s|.*github\.com[:/](.+/.+)|\1|')
            echo "Inferred repo: $REPO" >&2
        fi
    fi

    if [[ -z "$REPO" ]]; then
        echo "Usage: claude-deploy token <owner/repo> [--org <n>]" >&2
        exit 1
    fi

    infer_profile "$REPO"
    load_config "$PROFILE"

    JWT=$(generate_jwt)

    echo "JWT generated, looking up installation..." >&2

    INSTALL_ID=$(get_install_id "$REPO")
    echo "Installation ID: $INSTALL_ID" >&2

    TOKEN=$(gh api "/app/installations/$INSTALL_ID/access_tokens" \
        --method POST \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" \
        --jq '.token')

    EXPIRY_ISO=$(date -u -d '+1 hour' '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date -u -v+1H '+%Y-%m-%dT%H:%M:%SZ')
    EXPIRY_HUMAN=$(date -d '+1 hour' '+%H:%M %Z' 2>/dev/null || date -v+1H '+%H:%M %Z')
    echo "Token valid until: $EXPIRY_HUMAN" >&2

    # Push tok- file to sentinel branch so the watcher can pick it up
    _push_token_file "$PROFILE" "$TOKEN" "$EXPIRY_ISO" "$REPO"

    copy_or_print "$TOKEN" "Token copied to clipboard (valid until $EXPIRY_HUMAN)" --always-print
}

# Print one profile name per line (default, then named orgs).
# Used by cmd_profiles and bash completion.
_list_profile_names() {
    for f in "$CONFIG_DIR"/config "$CONFIG_DIR"/config-*; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f")
        [[ "$name" == "config" ]]  && echo "default" && continue
        [[ "$name" == config-* ]]  && echo "${name#config-}"
    done
}

cmd_profiles() {
    local names_only=0
    [[ "${1:-}" == "--names" ]] && names_only=1

    if [[ $names_only -eq 1 ]]; then
        _list_profile_names
        return
    fi

    echo "Configured orgs:"
    for f in "$CONFIG_DIR"/config "$CONFIG_DIR"/config-*; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f")
        [[ "$name" == "config" ]] && name="default"
        [[ "$name" == config-* ]] && name="${name#config-}"
        source "$f"
        echo "  $name — ${ACCOUNT_TYPE:-org} — App ID: $APP_ID, PEM: $PEM_PATH"
    done
}

cmd_status() {
    parse_profile "$@"
    load_config "$PROFILE"
    echo "Profile:      $PROFILE"
    echo "Account type: ${ACCOUNT_TYPE:-org}"
    echo "App ID:       $APP_ID"
    echo "PEM:          $PEM_PATH"
    [[ -f "$PEM_PATH" ]] && echo "PEM file:     ✓ exists" || echo "PEM file:     ✗ missing"
}

cmd_handover() {
    parse_profile "$@"
    REPO="${POSITIONAL[0]}"

    # Infer repo from git remote if not explicitly given and we're in a git repo
    if [[ -z "$REPO" ]] && git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
        local remote_url
        remote_url=$(git remote get-url origin 2>/dev/null || true)
        if [[ -n "$remote_url" ]]; then
            # Parse owner/repo from https or git remote URL
            REPO=$(echo "$remote_url" | sed -E 's|.*github\.com[:/](.+/.+)\.git.*|\1|; s|.*github\.com[:/](.+/.+)|\1|')
            echo "Inferred repo: $REPO" >&2
        fi
    fi

    # If no repo given, infer org from single configured org or require --org
    if [[ -z "$REPO" ]]; then
        if [[ "$PROFILE" == "default" ]]; then
            if ! infer_single_org; then
                echo "Usage: claude-deploy handover [<owner/repo>] [--org <n>]" >&2
                exit 1
            fi
        fi
    else
        infer_profile "$REPO"
    fi

    load_config "$PROFILE"

    echo "Generating token..." >&2

    JWT=$(generate_jwt)

    # Get installation ID — use repo if given, else org-level lookup
    if [[ -n "$REPO" ]]; then
        INSTALL_ID=$(get_install_id "$REPO")
    else
        INSTALL=$(gh api "/app/installations" \
            --header "Authorization: Bearer $JWT" \
            --header "Accept: application/vnd.github+json" \
            | jq "[.[] | select(.account.login == \"$PROFILE\")][0]")
        INSTALL_ID=$(echo "$INSTALL" | jq -r '.id')
        if [[ "$INSTALL_ID" == "null" || -z "$INSTALL_ID" ]]; then
            echo "Error: app not installed on '$PROFILE'" >&2
            exit 1
        fi
    fi

    # Get token first
    TOKEN=$(gh api "/app/installations/$INSTALL_ID/access_tokens" \
        --method POST \
        --header "Authorization: Bearer $JWT" \
        --header "Accept: application/vnd.github+json" \
        --jq '.token')

    # List repos using the installation token
    REPOS_JSON=$(gh api "/installation/repositories" \
        --header "Authorization: token $TOKEN" \
        --header "Accept: application/vnd.github+json" \
        | jq -r '.repositories[].full_name')

    EXPIRY_ISO=$(date -u -d '+1 hour' '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date -u -v+1H '+%Y-%m-%dT%H:%M:%SZ')
    EXPIRY=$(date -d '+1 hour' '+%H:%M %Z' 2>/dev/null || date -v+1H '+%H:%M %Z')

    # Push tok- file to sentinel branch for watcher auto-refresh
    _push_token_file "$PROFILE" "$TOKEN" "$EXPIRY_ISO" "$REPO"

    # Fetch context.md from the skill repo using the token
    SKILL_REPO="fluid-notion-labs/claude-deploy-skill"
    SKILL_DIR=$(mktemp -d)
    echo "Fetching context..." >&2
    git clone -q "https://x-access-token:$TOKEN@github.com/$SKILL_REPO.git" "$SKILL_DIR" 2>/dev/null
    if [[ -f "$SKILL_DIR/docs/context/context.md" ]]; then
        CONTEXT=$(cat "$SKILL_DIR/docs/context/context.md")
    else
        CONTEXT="(context.md not found in $SKILL_REPO)"
    fi
    rm -rf "$SKILL_DIR"

    # Infer skill repo — try org-specific first, fall back to fluid-notion-labs
    local REPO_OWNER
    REPO_OWNER=$(echo "$REPO" | cut -d'/' -f1)
    local SKILL_BOOTSTRAP_REPO="fluid-notion-labs/claude-deploy-skill"
    # If org has its own skill repo (checked via repos list), prefer it
    if echo "$REPOS_JSON" | grep -q "^${REPO_OWNER}/claude-deploy-skill$"; then
        SKILL_BOOTSTRAP_REPO="${REPO_OWNER}/claude-deploy-skill"
    fi

    # Build repo section
    if [[ -n "$REPO" ]]; then
        REPO_SECTION="Repo: \`$REPO\`"
        SESSION_TITLE="$REPO"
    else
        REPO_LIST=$(echo "$REPOS_JSON" | sed 's/^/- /')
        REPO_SECTION="Repos — ask user which to clone:
$REPO_LIST"
        SESSION_TITLE="$PROFILE"
    fi

    BLOB=$(cat << HANDOVER
## claude-deploy session — $SESSION_TITLE

$REPO_SECTION
Token (valid until $EXPIRY):
\`\`\`
$TOKEN
\`\`\`

Bootstrap (run this first):
\`\`\`sh
git clone -q https://x-access-token:$TOKEN@github.com/$SKILL_BOOTSTRAP_REPO.git /home/claude/claude-deploy-skill 2>/dev/null || true
\`\`\`

Clone and push:
\`\`\`sh
git clone https://x-access-token:$TOKEN@github.com/<owner>/<repo>.git /home/claude/<repo>
cd /home/claude/<repo>
git config user.email "claude@anthropic.com" && git config user.name "Claude"
git remote set-url origin https://x-access-token:$TOKEN@github.com/<owner>/<repo>.git
# Always commit via commit.sh — auto-refreshes token before push:
bash /home/claude/claude-deploy-skill/container/scripts/commit.sh /home/claude/<repo> "<message>"
\`\`\`

Constraints: no SSH, api.github.com blocked, raw.githubusercontent.com blocked, token expires in 1hr.
Token auto-refresh: \`claude-deploy-sentinel watch\` pushes a fresh \`tok-\` file to the sentinel branch 7min before expiry. \`commit.sh\` reads the latest token from the sentinel worktree before every push — no manual intervention needed.
On 401/403: run \`bash /home/claude/claude-deploy-skill/container/scripts/get-latest-token.sh\` first. If that fails, ask user to run \`claude-deploy token\`.

---

$CONTEXT
HANDOVER
)

    copy_or_print "$BLOB" "Handover copied to clipboard (token valid until $EXPIRY)"
}

cmd_open() {
    parse_profile "$@"
    load_config "$PROFILE"

    local url
    if [[ "${ACCOUNT_TYPE:-org}" == "user" || "$PROFILE" == "default" ]]; then
        url="https://github.com/settings/installations"
    else
        url="https://github.com/organizations/$PROFILE/settings/installations"
    fi

    echo "Opening: $url" >&2
    xdg-open "$url" 2>/dev/null || echo "$url"
}

cmd_update() {
    local dest
    dest=$(command -v claude-deploy 2>/dev/null || realpath "$0")
    _do_update --dest "$dest" || exit 1
}


# Sentinel branch name — all sentinel files live here, never on main

# Sentinel branch name — all sentinel files live here, never on main
SENTINEL_BRANCH="claude-deploy-sentinels"

# How long (seconds) before a stuck "running" sentinel is marked abandoned
SENTINEL_RUNNING_TIMEOUT=${CLAUDE_DEPLOY_SENTINEL_TIMEOUT:-600}

# Worker identity for optimistic locking (hostname + PID)
_sentinel_worker() { echo "${HOSTNAME:-$(hostname 2>/dev/null || echo host)}-$$"; }

# Generate a unique sentinel filename.
# Format: run-<main-ref-8>-<timestamp>-<random4>
# random suffix prevents collisions when multiple sentinels are created
# in the same second against the same commit.
_push_token_file() {
    # _push_token_file <org> <token> <expiry-iso> [<repo>]
    # Writes a tok- file to the sentinel branch so the Rust watcher picks it up.
    local org="$1" token="$2" expiry="$3" repo="${4:-}"
    local ts name wt repo_dir

    # Find the repo dir (cwd or infer from git remote)
    repo_dir=$(git rev-parse --show-toplevel 2>/dev/null || true)
    [[ -z "$repo_dir" ]] && return 0  # not in a git repo, skip silently

    wt="$repo_dir/.git/claude-sentinel-wt"
    [[ -d "$wt" ]] || return 0  # watcher not running, skip silently

    ts=$(date -u '+%Y%m%dT%H%M%S')
    name="tok-${org}-${ts}"

    # Get repos list if we have a token
    local repos=""
    if [[ -n "$repo" ]]; then
        repos="  $repo"
    fi

    cat > "$wt/$name" << TOKEOF
type: token
org: $org
token: $token
expires: $expiry
repos:
$repos
TOKEOF

    (cd "$repo_dir" && \
        git -C "$wt" add "$name" && \
        git -C "$wt" commit -m "token: $name" -q && \
        git -C "$wt" push origin HEAD:claude-deploy-sentinels -q \
    ) 2>/dev/null || true
    echo "Token file pushed to sentinel branch: $name" >&2
}

_sentinel_new_name() {
    local repo="${1:-$PWD}"
    local ref ts rand
    ref=$(git -C "$repo" rev-parse --short=8 HEAD 2>/dev/null || echo "noref")
    ts=$(date -u '+%Y%m%dT%H%M%S')
    rand=$(head -c 2 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 4)
    echo "run-${ref}-${ts}-${rand}"
}

# Parse a sentinel file into variables.
# Sets: s_status, s_main_ref, s_created, s_cmd, s_capture, s_msg, s_worker, s_ran, s_script_body
_sentinel_parse() {
    local file="$1"
    s_status="" s_main_ref="" s_created="" s_cmd="" s_capture="" s_msg="" \
        s_worker="" s_ran="" s_script_body=""
    local in_body=0
    while IFS= read -r line; do
        if [[ $in_body -eq 0 ]]; then
            if   [[ "$line" =~ ^status:[[:space:]]*(.+)$    ]]; then s_status="${BASH_REMATCH[1]}"
            elif [[ "$line" =~ ^main-ref:[[:space:]]*(.+)$  ]]; then s_main_ref="${BASH_REMATCH[1]}"
            elif [[ "$line" =~ ^created:[[:space:]]*(.+)$   ]]; then s_created="${BASH_REMATCH[1]}"
            elif [[ "$line" =~ ^cmd:[[:space:]]*(.+)$       ]]; then s_cmd="${BASH_REMATCH[1]}"
            elif [[ "$line" =~ ^capture:[[:space:]]*(.+)$   ]]; then s_capture="${BASH_REMATCH[1]}"
            elif [[ "$line" =~ ^msg:[[:space:]]*(.+)$       ]]; then s_msg="${BASH_REMATCH[1]}"
            elif [[ "$line" =~ ^worker:[[:space:]]*(.+)$    ]]; then s_worker="${BASH_REMATCH[1]}"
            elif [[ "$line" =~ ^ran:[[:space:]]*(.+)$       ]]; then s_ran="${BASH_REMATCH[1]}"
            elif [[ -z "$line" ]]; then in_body=1
            fi
        else
            s_script_body+="$line"$'\n'
        fi
    done < "$file"
}

# Update a field in a sentinel file in-place.
# If the key exists, replace it. If not, insert before the first blank line
# (the header/body separator) — never overwrite the blank line itself.
_sentinel_set_field() {
    local file="$1" key="$2" val="$3"
    if grep -q "^${key}:" "$file"; then
        sed -i "s|^${key}:.*|${key}: ${val}|" "$file"
    else
        python3 - "$file" "$key" "$val" <<'PYEOF'
import sys
path, key, val = sys.argv[1], sys.argv[2], sys.argv[3]
lines = open(path).readlines()
insert_at = next((i for i, l in enumerate(lines) if l.strip() == ""), len(lines))
lines.insert(insert_at, f"{key}: {val}\n")
open(path, "w").writelines(lines)
PYEOF
    fi
}

# Ensure sentinel branch exists locally and on origin.
# Leaves repo on original branch.
_sentinel_branch_ensure() {
    local repo="$1"
    local orig_branch
    orig_branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD)

    # Fetch remote first — may already exist on origin
    git -C "$repo" fetch origin "$SENTINEL_BRANCH" -q 2>/dev/null || true

    if git -C "$repo" rev-parse --verify "origin/$SENTINEL_BRANCH" &>/dev/null; then
        # Remote exists — set up local tracking branch if missing
        if ! git -C "$repo" rev-parse --verify "$SENTINEL_BRANCH" &>/dev/null; then
            git -C "$repo" checkout --track "origin/$SENTINEL_BRANCH" -q
            git -C "$repo" checkout "$orig_branch" -q
        fi
        return
    fi

    # Neither local nor remote exists — create orphan
    git -C "$repo" checkout --orphan "$SENTINEL_BRANCH" -q
    git -C "$repo" reset --hard -q
    git -C "$repo" commit --allow-empty -m "init: claude-deploy-sentinels branch" -q
    git -C "$repo" push origin "$SENTINEL_BRANCH" -q
    git -C "$repo" checkout "$orig_branch" -q
    echo "  → created sentinel branch: $SENTINEL_BRANCH" >&2
}

# Attempt to claim a sentinel via optimistic push.
# Writes status:claiming + worker, pushes. Re-fetches to verify we own it.
# Returns 0 if claimed, 1 if another worker got it first.
# Precondition: sentinel branch is checked out and up to date.
_sentinel_claim() {
    local repo="$1" sentinel_file="$2"
    local worker
    worker=$(_sentinel_worker)

    _sentinel_set_field "$sentinel_file" "status" "claiming"
    _sentinel_set_field "$sentinel_file" "worker" "$worker"
    git -C "$repo" add "$sentinel_file"
    git -C "$repo" commit -m "sentinel: claiming $(basename "$sentinel_file") [$worker]" -q

    # Attempt push — fails non-ff if another watcher pushed first
    if ! git -C "$repo" push origin "$SENTINEL_BRANCH" -q 2>/dev/null; then
        git -C "$repo" reset --hard "origin/$SENTINEL_BRANCH" -q 2>/dev/null || true
        return 1
    fi

    # Verify our commit landed on origin (handles simultaneous push edge case)
    git -C "$repo" fetch origin "$SENTINEL_BRANCH" -q 2>/dev/null || true
    local origin_worker
    origin_worker=$(git -C "$repo" show "origin/$SENTINEL_BRANCH:$(basename "$sentinel_file")" 2>/dev/null \
        | grep "^worker:" | head -1 | sed 's/^worker:[[:space:]]*//')

    if [[ "$origin_worker" != "$worker" ]]; then
        git -C "$repo" pull --ff-only origin "$SENTINEL_BRANCH" -q 2>/dev/null || true
        return 1
    fi

    return 0
}

# Check for sentinels stuck in running/claiming and mark them abandoned.
# Safe to call from any watcher — uses optimistic push to avoid double-abandon.
_sentinel_reap_abandoned() {
    local repo="$1"
    local now
    now=$(date '+%s')

    local all_sentinels
    all_sentinels=$(git -C "$repo" ls-tree -r --name-only "origin/$SENTINEL_BRANCH" 2>/dev/null \
        | grep "^run-" || true)
    [[ -z "$all_sentinels" ]] && return

    local orig_branch
    orig_branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD)

    while IFS= read -r sname; do
        local content
        content=$(git -C "$repo" show "origin/$SENTINEL_BRANCH:$sname" 2>/dev/null) || continue
        local status ran
        status=$(grep "^status:" <<< "$content" | head -1 | sed 's/^status:[[:space:]]*//')
        [[ "$status" != "running" && "$status" != "claiming" ]] && continue

        ran=$(grep "^ran:" <<< "$content" | head -1 | sed 's/^ran:[[:space:]]*//')
        [[ -z "$ran" ]] && ran=$(grep "^created:" <<< "$content" | head -1 | sed 's/^created:[[:space:]]*//')
        [[ -z "$ran" ]] && continue

        local ran_epoch
        ran_epoch=$(date -d "$ran" '+%s' 2>/dev/null \
            || date -j -f '%Y-%m-%dT%H:%M:%S' "$ran" '+%s' 2>/dev/null \
            || echo 0)
        local age=$(( now - ran_epoch ))

        if [[ $age -gt $SENTINEL_RUNNING_TIMEOUT ]]; then
            local prev_worker
            prev_worker=$(grep "^worker:" <<< "$content" | head -1 | sed 's/^worker:[[:space:]]*//')
            echo "  ⚠  sentinel stuck >$(( SENTINEL_RUNNING_TIMEOUT / 60 ))m [$prev_worker]: $sname — abandoning" >&2

            git -C "$repo" checkout "$SENTINEL_BRANCH" -q
            git -C "$repo" pull --ff-only origin "$SENTINEL_BRANCH" -q 2>/dev/null || {
                git -C "$repo" checkout "$orig_branch" -q
                continue
            }

            local sentinel_file="$repo/$sname"
            _sentinel_set_field "$sentinel_file" "status" "abandoned"
            _sentinel_set_field "$sentinel_file" "abandoned" "$(date '+%Y-%m-%dT%H:%M:%S')"
            {
                echo ""
                echo "# --- abandoned ---"
                echo "# Marked abandoned after ${age}s. Previous worker: ${prev_worker:-(unknown)}"
            } >> "$sentinel_file"

            git -C "$repo" add "$sentinel_file"
            git -C "$repo" commit -m "sentinel: abandoned $sname (stuck ${age}s)" -q
            # Best-effort push — if we race, another watcher already handled it
            git -C "$repo" push origin "$SENTINEL_BRANCH" -q 2>/dev/null \
                || git -C "$repo" reset --hard "origin/$SENTINEL_BRANCH" -q 2>/dev/null || true

            git -C "$repo" checkout "$orig_branch" -q
        fi
    done <<< "$all_sentinels"
}

# Run a single sentinel. Called after claim is secured.
# Precondition: sentinel branch checked out, claim pushed, main_branch != sentinel branch.
_sentinel_run() {
    local repo="$1" main_branch="$2" sentinel_file="$3"
    local ts
    ts=$(date '+%Y-%m-%dT%H:%M:%S')

    # Safety guard: refuse if main_branch is the sentinel branch
    if [[ "$main_branch" == "$SENTINEL_BRANCH" ]]; then
        echo "  ✗ BUG: main_branch is sentinel branch — refusing to prevent corruption" >&2
        _sentinel_set_field "$sentinel_file" "status" "failure"
        _sentinel_set_field "$sentinel_file" "completed" "$ts"
        {
            echo ""
            echo "# --- log ---"
            echo "# ERROR: main_branch resolved to sentinel branch. Aborting."
        } >> "$sentinel_file"
        git -C "$repo" add "$sentinel_file"
        git -C "$repo" commit -m "sentinel: failure (safety) $(basename "$sentinel_file")" -q
        git -C "$repo" push origin "$SENTINEL_BRANCH" -q 2>/dev/null || true
        return 1
    fi

    _sentinel_parse "$sentinel_file"

    echo "  → running sentinel: $(basename "$sentinel_file")"
    echo "     main-ref: $s_main_ref  capture: ${s_capture:-(none)}"

    # Transition: claiming → running
    _sentinel_set_field "$sentinel_file" "status" "running"
    _sentinel_set_field "$sentinel_file" "ran" "$ts"
    git -C "$repo" add "$sentinel_file"
    git -C "$repo" commit -m "sentinel: running $(basename "$sentinel_file")" -q
    git -C "$repo" push origin "$SENTINEL_BRANCH" -q

    local tmpscript run_log exit_ok
    tmpscript=$(mktemp /tmp/claude-run-XXXXXX.sh)
    run_log=$(mktemp /tmp/claude-run-log-XXXXXX.txt)
    {
        echo "#!/usr/bin/env bash"
        echo "set -e"
        echo "cd $(printf '%q' "$repo")"
        echo "$s_script_body"
    } > "$tmpscript"
    chmod +x "$tmpscript"

    # Checkout main and pull latest before running
    git -C "$repo" checkout "$main_branch" -q
    git -C "$repo" pull --ff-only origin "$main_branch" -q 2>/dev/null \
        || echo "  ⚠  could not pull main before run — proceeding on current HEAD" >&2

    if bash "$tmpscript" 2>&1 | tee "$run_log"; then
        exit_ok=1
        echo "  → script succeeded"
    else
        exit_ok=0
        echo "  → script FAILED"
    fi
    rm -f "$tmpscript"

    local result_ref=""

    if [[ -n "$s_capture" ]]; then
        if [[ -d "$repo/$s_capture" ]]; then
            git -C "$repo" add "$repo/$s_capture"
            local commit_msg="${s_msg:-sentinel results: $(basename "$sentinel_file")}"
            if git -C "$repo" commit -m "$commit_msg" -q 2>/dev/null; then
                if git -C "$repo" push origin "$main_branch" -q 2>/dev/null; then
                    result_ref=$(git -C "$repo" rev-parse HEAD)
                    echo "  → captured to main: $commit_msg (${result_ref:0:8})"
                else
                    echo "  ⚠  capture committed but push to main failed — run: git -C $repo push origin $main_branch" >&2
                fi
            else
                echo "  ℹ  capture: nothing new to commit in $s_capture" >&2
            fi
        else
            echo "  ⚠  capture dir not found: $repo/$s_capture" >&2
        fi
    fi

    # Back to sentinel branch to write outcome
    git -C "$repo" checkout "$SENTINEL_BRANCH" -q
    git -C "$repo" pull --ff-only origin "$SENTINEL_BRANCH" -q 2>/dev/null \
        || echo "  ⚠  could not pull sentinel branch before writing outcome" >&2

    local final_status
    [[ $exit_ok -eq 1 ]] && final_status="success" || final_status="failure"

    _sentinel_set_field "$sentinel_file" "status" "$final_status"
    _sentinel_set_field "$sentinel_file" "completed" "$(date '+%Y-%m-%dT%H:%M:%S')"
    [[ -n "$result_ref" ]] && _sentinel_set_field "$sentinel_file" "result-ref" "$result_ref"

    {
        echo ""
        echo "# --- log ---"
        sed 's/^/# /' "$run_log"
    } >> "$sentinel_file"
    rm -f "$run_log"

    git -C "$repo" add "$sentinel_file"
    git -C "$repo" commit -m "sentinel: $final_status $(basename "$sentinel_file")" -q
    git -C "$repo" push origin "$SENTINEL_BRANCH" -q

    echo "  → sentinel $final_status ✓"
    git -C "$repo" checkout "$main_branch" -q
}

cmd_watch() {
    local commands_mode=0
    for arg in "$@"; do
        [[ "$arg" == "--commands" ]] && commands_mode=1
    done

    local repo="${PWD}"
    local interval=5

    if [[ ! -d "$repo/.git" ]]; then
        echo "Error: not a git repo: $repo" >&2
        exit 1
    fi

    local branch
    branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD)

    # Guard: refuse to watch from the sentinel branch
    if [[ "$branch" == "$SENTINEL_BRANCH" ]]; then
        echo "Error: started from sentinel branch — checkout your working branch first" >&2
        exit 1
    fi

    local mode_label=""
    [[ $commands_mode -eq 1 ]] && mode_label=" [--commands]"
    echo "Watching $repo [$branch]${mode_label} (every ${interval}s) — Ctrl-C to stop"

    [[ $commands_mode -eq 1 ]] && _sentinel_branch_ensure "$repo"

    local last_main_ref
    last_main_ref=$(git -C "$repo" rev-parse HEAD 2>/dev/null)

    while true; do
        local ts
        ts=$(date '+%H:%M:%S')

        if [[ $commands_mode -eq 1 ]]; then
            git -C "$repo" fetch origin "$SENTINEL_BRANCH" -q 2>/dev/null

            # Reap stuck sentinels
            _sentinel_reap_abandoned "$repo"

            local all_sentinels
            all_sentinels=$(git -C "$repo" ls-tree -r --name-only "origin/$SENTINEL_BRANCH" 2>/dev/null \
                | grep "^run-" | sort || true)

            if [[ -n "$all_sentinels" ]]; then
                while IFS= read -r sentinel_name; do
                    local sentinel_status
                    sentinel_status=$(git -C "$repo" show "origin/$SENTINEL_BRANCH:$sentinel_name" 2>/dev/null \
                        | grep "^status:" | head -1 | sed 's/^status:[[:space:]]*//')

                    if [[ "$sentinel_status" == "new" ]]; then
                        echo "[$ts] ⚡ sentinel: $sentinel_name"

                        git -C "$repo" checkout "$SENTINEL_BRANCH" -q
                        if ! git -C "$repo" pull --ff-only origin "$SENTINEL_BRANCH" -q 2>/dev/null; then
                            echo "  ⚠  sentinel branch pull failed — skipping $sentinel_name" >&2
                            git -C "$repo" checkout "$branch" -q
                            continue
                        fi

                        if ! _sentinel_claim "$repo" "$repo/$sentinel_name"; then
                            echo "  ℹ  $sentinel_name claimed by another worker — skipping" >&2
                            git -C "$repo" checkout "$branch" -q
                            continue
                        fi

                        _sentinel_run "$repo" "$branch" "$repo/$sentinel_name"
                        ts=$(date '+%H:%M:%S')
                        echo "[$ts] ✓ done"
                    fi
                done <<< "$all_sentinels"
            fi
        fi

        # Watch main — take ref after sentinel work to avoid stale before/after
        git -C "$repo" pull --ff-only origin "$branch" -q 2>/dev/null
        local after
        after=$(git -C "$repo" rev-parse HEAD 2>/dev/null)

        if [[ "$last_main_ref" != "$after" ]]; then
            local new_commits
            new_commits=$(git -C "$repo" log --oneline "${last_main_ref}..${after}" 2>/dev/null | head -5)
            echo "[$ts] ✓ main: $new_commits"
            last_main_ref="$after"
        fi

        sleep "$interval"
    done
}
# Skip dispatch when sourced for unit tests
if [[ "${CLAUDE_DEPLOY_TEST:-0}" != "1" ]]; then
case "$COMMAND" in
    setup)    cmd_setup "$@" ;;
    token)    cmd_token "$@" ;;
    handover) cmd_handover "$@" ;;
    open)     cmd_open "$@" ;;
    update)   cmd_update ;;

    watch)    cmd_watch "$@" ;;
    queue)    cmd_queue "$@" ;;
    config)   parse_profile "$@"; cmd_config ;;
    profiles) cmd_profiles ;;
    status)   cmd_status "$@" ;;
    *)        usage ;;
esac
fi
